# ApiCoreX Core — example environment.
# Copy to .env and fill in real values. Never commit .env (it is gitignored).

# ── Required ───────────────────────────────────────────────────────────────
# Shared key plugins present when they register with Core. Also authenticates
# Core to Identity's internal /internal/introspect endpoint, which Core calls
# on every request to resolve the opaque device token in the Authorization
# header — Core never parses or stores tokens itself. Must match the Identity
# plugin's PLUGIN_API_KEY.
PLUGIN_API_KEY=change-me-plugin-key

# ── Server ─────────────────────────────────────────────────────────────────
HTTP_PORT=:8080

# ── Optional: plugin security ──────────────────────────────────────────────
# Comma-separated plugin names allowed to register. Empty = allow any (dev only).
# PLUGIN_ALLOWLIST=identity,billing

# ── Optional: distributed tracing ──────────────────────────────────────────
# OTLP endpoint (e.g. Jaeger/Tempo). If unset, tracing is a no-op.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Optional: protection limits ────────────────────────────────────────────
# Per-plugin overrides go in a YAML file (see config.example.yaml).
# CONFIG_FILE=./config.yaml
# These env vars override the global default instead:
# RATE_PER_SEC=1000
# BULKHEAD_MAX=100
# CB_THRESHOLD=5
# CB_RESET_TIMEOUT=30s
# REQUEST_TIMEOUT=30s
# HEALTH_INTERVAL=30s
