# ApiCoreX Core — example environment.
# Copy to .env and fill in real values. Never commit .env (it is gitignored).

# ── Required ───────────────────────────────────────────────────────────────
# HS256 secret used to VERIFY access tokens. Must match the Identity plugin's
# JWT_SECRET. Use a long, random value in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Shared key plugins present when they register with Core.
PLUGIN_API_KEY=change-me-plugin-key

# ── Server ─────────────────────────────────────────────────────────────────
HTTP_PORT=:8080

# ── Optional: plugin security ──────────────────────────────────────────────
# Comma-separated plugin names allowed to register. Empty = allow any (dev only).
# PLUGIN_ALLOWLIST=identity,billing

# ── Optional: logout / token revocation ────────────────────────────────────
# Enables an access-token denylist so logout takes effect immediately.
# Shared with the Identity plugin. If unset, logout only revokes refresh tokens.
# REDIS_URL=redis://localhost:6379/0

# ── Optional: distributed tracing ──────────────────────────────────────────
# OTLP endpoint (e.g. Jaeger/Tempo). If unset, tracing is a no-op.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Optional: protection limits ────────────────────────────────────────────
# Per-plugin overrides go in a YAML file (see config.example.yaml).
# CONFIG_FILE=./config.yaml
# These env vars override the global default instead:
# RATE_PER_SEC=1000
# BULKHEAD_MAX=100
# CB_THRESHOLD=5
# CB_RESET_TIMEOUT=30s
# REQUEST_TIMEOUT=30s
# HEALTH_INTERVAL=30s
